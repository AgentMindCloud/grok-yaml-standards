{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "grok-config.yaml",
  "description": "Official schema for grok-config.yaml – v1.2.0",
  "type": "object",
  "required": ["version", "author", "compatibility"],
  "properties": {
    "version": { "type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$" },
    "author": { "type": "string" },
    "compatibility": { "type": "array", "items": { "type": "string" } },
    "grok": {
      "type": "object",
      "properties": {
        "default_model": { "type": "string" },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "max_tokens": { "type": "integer" },
        "personality": { "type": "string" }
      }
    },
    "context": { "type": "object" },
    "privacy": { "type": "object" },
    "shortcuts": { "type": "object" }
  }
}
