{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "grok-workflow.yaml",
  "description": "Official schema for grok-workflow.yaml – v1.2.0",
  "type": "object",
  "required": ["version", "author", "compatibility"],
  "properties": {
    "version": { "type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$" },
    "author": { "type": "string" },
    "compatibility": { "type": "array", "items": { "type": "string" } },
    "workflows": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "trigger": { "type": "string" },
          "steps": { "type": "array" }
        }
      }
    }
  }
}
