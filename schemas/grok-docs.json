{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "grok-docs.yaml",
  "description": "Official schema for grok-docs.yaml – v1.2.0",
  "type": "object",
  "required": ["version", "author", "compatibility"],
  "properties": {
    "version": { "type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$" },
    "author": { "type": "string" },
    "compatibility": { "type": "array", "items": { "type": "string" } },
    "docs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "target": { "type": "string" },
          "sections": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
