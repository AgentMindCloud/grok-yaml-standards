{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grokyaml.dev/schemas/v1.2.0/grok-tools.schema.json",
  "title": "grok-tools v1.2.0",
  "description": "Official JSON Schema for grok-tools.yaml — the canonical tool registry. Every tool declares a formal contract: typed `parameters`, typed `returns`, an explicit `errors` vocabulary, and a `security` block. Referenced by grok-agent.yaml and grok-workflow.yaml. Compatible with grok-install.yaml@1.0+ and grok@2026.4+.",
  "type": "object",
  "required": ["version", "author", "compatibility", "tools"],
  "additionalProperties": false,
  "definitions": {
    "jsonSchemaFragment": {
      "type": "object",
      "description": "A permissive JSON Schema fragment used inside parameters/returns blocks. Supports standard draft-07 keywords.",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "integer", "number", "boolean", "array", "object", "null"]
        },
        "description": { "type": "string", "maxLength": 500 },
        "default": {},
        "enum": { "type": "array", "minItems": 1 },
        "format": {
          "type": "string",
          "enum": ["date-time", "date", "time", "email", "uri", "uuid", "ipv4", "ipv6"]
        },
        "pattern": { "type": "string" },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" },
        "minLength": { "type": "integer", "minimum": 0 },
        "maxLength": { "type": "integer", "minimum": 0 },
        "minItems": { "type": "integer", "minimum": 0 },
        "maxItems": { "type": "integer", "minimum": 0 },
        "properties": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/jsonSchemaFragment" }
        },
        "required": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "items": { "$ref": "#/definitions/jsonSchemaFragment" },
        "additionalProperties": {}
      }
    },
    "errorDefinition": {
      "type": "object",
      "description": "A single error code the tool may raise.",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "description": "UPPER_SNAKE_CASE machine-readable error code.",
          "pattern": "^[A-Z][A-Z0-9_]{1,63}$"
        },
        "message": {
          "type": "string",
          "description": "Human-readable explanation of when this error is raised.",
          "minLength": 5,
          "maxLength": 300
        }
      }
    },
    "rateLimit": {
      "type": "object",
      "description": "Per-tool throttling limits.",
      "additionalProperties": false,
      "properties": {
        "requests_per_minute": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6000
        },
        "requests_per_day": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        }
      }
    },
    "securityBlock": {
      "type": "object",
      "description": "Security constraints for the tool. Keys vary by category; unknown keys are permitted so new categories can declare their own controls.",
      "properties": {
        "requires_auth": { "type": "boolean" },
        "auth_provider": {
          "type": "string",
          "enum": ["github", "x_oauth2", "google", "slack", "stripe", "aws", "gcp", "azure", "custom"]
        },
        "approval_required": { "type": "boolean" },
        "blocks_if_require_approval_false": { "type": "boolean" },
        "read_only": { "type": "boolean" },
        "pure_transform": { "type": "boolean" },
        "https_only": { "type": "boolean" },
        "ssrf_protection": { "type": "boolean" },
        "blocked_ranges": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "path_traversal_regex": { "type": "string" },
        "no_symlink_follow": { "type": "boolean" },
        "overwrite_default": { "type": "boolean" },
        "max_bytes": { "type": "integer", "minimum": 1 },
        "respects_gitignore": { "type": "boolean" },
        "sandbox": { "type": "boolean" },
        "network_isolated_by_default": { "type": "boolean" },
        "requires_safety_profile": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["strict", "balanced", "research"]
          },
          "uniqueItems": true
        },
        "requires_explicit": { "type": "string" },
        "no_bulk_collection": { "type": "boolean" },
        "own_tweets_only": { "type": "boolean" },
        "uses_grok_builtin": { "type": "boolean" },
        "no_sensitive_data_warning": { "type": "boolean" },
        "encrypted_at_rest": { "type": "boolean" },
        "scope": { "type": "string", "enum": ["agent", "workspace", "global"] },
        "scoped_to_repo": { "type": "boolean" },
        "draft_default": { "type": "boolean" },
        "owner_pattern": { "type": "string" },
        "repo_pattern": { "type": "string" },
        "delegates_to": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "inherits_security_of_delegates": { "type": "boolean" },
        "rate_limit": { "$ref": "#/definitions/rateLimit" }
      }
    }
  },
  "properties": {
    "version": {
      "type": "string",
      "description": "Semantic version of this tool registry file.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "examples": ["1.2.0"]
    },
    "author": {
      "type": "string",
      "description": "X handle of the registry maintainer, prefixed with '@'.",
      "pattern": "^@[A-Za-z0-9_]{1,50}$"
    },
    "compatibility": {
      "type": "array",
      "description": "Platform specs this file is tested and compatible with.",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9._-]+@[0-9]+\\.[0-9]+(\\+|\\.[0-9]+)?$"
      }
    },
    "tools": {
      "type": "object",
      "description": "Map of tool identifiers to formal contracts. Keys are referenced from grok-agent.yaml 'tools' arrays and grok-workflow.yaml step 'action' fields.",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]{1,63}$"
      },
      "additionalProperties": {
        "type": "object",
        "description": "A single tool definition.",
        "required": ["category", "description", "parameters", "returns", "security"],
        "additionalProperties": false,
        "properties": {
          "category": {
            "type": "string",
            "description": "Functional category grouping related tools together.",
            "enum": [
              "filesystem",
              "shell",
              "x_platform",
              "github",
              "web",
              "memory",
              "workflow"
            ]
          },
          "description": {
            "type": "string",
            "description": "One-sentence explanation of what this tool does.",
            "minLength": 10,
            "maxLength": 500
          },
          "parameters": {
            "allOf": [
              { "$ref": "#/definitions/jsonSchemaFragment" },
              {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": { "const": "object" }
                }
              }
            ]
          },
          "returns": {
            "allOf": [
              { "$ref": "#/definitions/jsonSchemaFragment" },
              {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": { "const": "object" }
                }
              }
            ]
          },
          "errors": {
            "type": "array",
            "description": "Explicit error vocabulary this tool may raise.",
            "items": { "$ref": "#/definitions/errorDefinition" },
            "uniqueItems": true
          },
          "security": { "$ref": "#/definitions/securityBlock" },
          "enabled": {
            "type": "boolean",
            "description": "Set to false to disable this tool without removing its definition.",
            "default": true
          }
        }
      }
    }
  }
}
